# URL publique du site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL de ton projet Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Cle publique anon Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cle service role Supabase, serveur uniquement
SUPABASE_SERVICE_ROLE_KEY=

# Cle secrete Stripe
STRIPE_SECRET_KEY=

# Secret du webhook Stripe
STRIPE_WEBHOOK_SECRET=

# URL du PDF livre apres paiement
NEXT_PUBLIC_EBOOK_URL=https://example.com/ebook.pdf

# Conseil:
# - ne mets pas de guillemets autour des valeurs
# - n'expose jamais SUPABASE_SERVICE_ROLE_KEY ou STRIPE_SECRET_KEY cote client

# DEV ONLY - Bouton connexion rapide (admin/membre test)
# Mettre a true pour activer le bouton DEV sur Vercel (ne pas activer en prod finale)
NEXT_PUBLIC_DEV_LOGIN=false
